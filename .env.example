# Required for local development
# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Required by Drizzle/Postgres queries.
# Example: postgresql://user:password@host/database?sslmode=require
POSTGRES_URL=


# Public app URL used for metadata/canonical URL generation.
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Optional: set to 1 to serve the app under /demo.
# next.config.ts derives NEXT_PUBLIC_BASE_PATH from this value.
IS_DEMO=0

# Optional: Redis enables production rate limiting and resumable chat streams.
REDIS_URL=

# Optional: required only for image/file uploads through @vercel/blob.
BLOB_READ_WRITE_TOKEN=

# Optional: local server port. Defaults to 3000.
PORT=3000

# Optional: Playwright/test-only switches.
PLAYWRIGHT=
PLAYWRIGHT_TEST_BASE_URL=
CI_PLAYWRIGHT=
